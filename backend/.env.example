# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-prod
JWT_SECRET_KEY=change-me-too

# PostgreSQL (source of truth — all finance)
DATABASE_URL=postgresql://baytara:baytara@localhost:5432/baytara

# MongoDB (non-financial high-volume logs) — used from Phase 5
MONGO_URL=mongodb://localhost:27017/baytara_logs

# Redis (sessions, rate-limit, idempotency) — used from Phase 4
REDIS_URL=redis://localhost:6379/0

# CORS: comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173
